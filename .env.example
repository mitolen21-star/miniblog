# Pasos para integrar la base de datos de su servidor.

# .env.example
# ¿Para qué sirve?: Es una plantilla segura de las variables de entorno para que el proyecto funcione.
# Instrucciones de uso:
# 1. Copia este archivo y cámbiale el nombre a ".env" (sin la palabra example).
# 2. Reemplaza los datos falsos por las credenciales reales de tu base de datos.
# IMPORTANTE: El archivo ".env" real nunca se debe subir a GitHub por seguridad.


DATABASE_URL=postgresql://tu_usuario:tu_contraseña@tu_servidor:tu_puerto/tu_base_de_datos